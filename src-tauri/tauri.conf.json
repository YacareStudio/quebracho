{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quebracho",
  "version": "0.0.3",
  "identifier": "com.yacarestudio.quebracho",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Quebracho",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http://localhost:* http://127.0.0.1:*; img-src 'self' data: blob: asset: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; font-src 'self' data:; media-src 'self' data: blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": false,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3MTZFQzU0QzAxMTIxQzIKUldUQ0lSSEFWT3dXOTBQblZ2TnJtanpqQlNxZm9iV2JLK1Y0U1NqMSsyZDdLSmkrMXRrTUora3gK",
      "endpoints": [
        "https://github.com/YacareStudio/quebracho/releases/latest/download/latest.json"
      ]
    }
  }
}
