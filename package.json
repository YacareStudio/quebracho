{
  "name": "quebracho",
  "version": "0.0.2",
  "description": "Quebracho — agentic code editor by Yacare Studio (Chaco, Argentina)",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "tauri build --bundles nsis",
    "build:all": "tauri build",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets",
    "format:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "lint": "npm run typecheck && npm run lint:rust",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "ci:check": "npm run build:web && npm run format:check && npm run lint && npm run test",
    "updater:keygen": "tauri signer generate",
    "updater:latest:init": "node scripts/create-latest-template.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@monaco-editor/react": "^4.6.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "diff": "^9.0.0",
    "lucide-react": "^0.344.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "@tailwindcss/vite": "^4.3.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^5.1.3"
  }
}
